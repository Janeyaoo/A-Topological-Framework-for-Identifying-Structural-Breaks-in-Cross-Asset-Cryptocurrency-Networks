@article{RN4321,
   author = {Rogers, L. C. G. and Satchell, S. E.},
   title = {Estimating Variance From High, Low and Closing Prices},
   journal = {The Annals of Applied Probability},
   volume = {1},
   number = {4},
   pages = {504–512},
   abstract = {[The log of the price of a share is commonly modelled as a Brownian motion with drift, σ Bt + ct, where the constants c and σ are unknown. In order to use the Black-Scholes option pricing formula, one needs an estimate of σ, though not of c. In this paper, we propose a new estimator of σ based on the high, low, and closing prices in a day's trading. This estimator has the merit of being unbiased whatever the drift c. In common with other estimators of σ, the approximation of the true high and low values of the drifting Brownian motion by the high and low values of a random walk introduces error, often quite a serious error. We shall show how a simple correction can overcome this error almost completely.]},
   ISSN = {10505164},
   url = {http://www.jstor.org/stable/2959703},
   year = {1991},
   type = {Journal Article}
}

